# =============================================================================
# Neuro IT — Environment Variables
# Copy this file to .env.local and fill in real values before running.
# NEVER commit .env.local to git.
# =============================================================================

# ── Database (PostgreSQL — Neon, Supabase, or Railway) ─────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/neuro_it?sslmode=require"

# ── NextAuth ────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_SECRET_AT_LEAST_32_CHARS"
NEXTAUTH_URL="https://neuro-it.co.uk"          # Change to http://localhost:3000 for dev

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Email (Magic Link — Resend recommended) ──────────────────────────────────
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="re_XXXXXXXXXXXXXXXXXXXX"
EMAIL_FROM="noreply@neuro-it.co.uk"

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Google Maps ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIza..."

# ── Contact / WhatsApp ───────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="447700000000"   # Format: country code + number, no +
NEXT_PUBLIC_PHONE_NUMBER="02000000000"

# ── App URL (public) ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://neuro-it.co.uk"
